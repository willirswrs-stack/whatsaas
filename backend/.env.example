# Server Configuration
NODE_ENV=development
PORT=3333

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=wathsaas
DATABASE_PASSWORD=wathsaas_secret_2024
DATABASE_NAME=wathsaas

# Redis (Queue & Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication (JWT)
JWT_SECRET=super-secret-key-change-this-in-production
JWT_EXPIRATION=7h

# Evolution API (WhatsApp Provider)
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=change-this-to-match-evolution-global-key

# Webhook Configuration
# Em desenvolvimento local, use um túnel (Ngrok) ou o próprio endereço local se Evolution estiver na mesma rede Docker
WEBHOOK_URL=http://host.docker.internal:3333/api/v1/evolution/webhook

# CORS (Frontend URL)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
