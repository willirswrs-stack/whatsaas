# ============================================
# WhatSaas - Production Environment Variables
# ============================================
# 1. Copy this file to .env.production
# 2. Generate all secrets and fill in values
# 3. NEVER commit .env.production to git
# ============================================

# ---- Database ----
DATABASE_USER=wathsaas
DATABASE_PASSWORD=GENERATE_STRONG_PASSWORD_HERE
DATABASE_NAME=wathsaas

# ---- Redis ----
REDIS_PASSWORD=GENERATE_STRONG_PASSWORD_HERE

# ---- Auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(30).toString('base64'))"
JWT_SECRET=GENERATE_RANDOM_SECRET_HERE
JWT_EXPIRATION=7h

# ---- Evolution API ----
EVOLUTION_API_KEY=GENERATE_STRONG_KEY_HERE

# ---- Webhooks ----
# Your public domain where Evolution can reach the backend
WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/evolution

# ---- CORS ----
CORS_ORIGINS=https://your-domain.com

# ---- Frontend Build ----
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1

# ---- Uploads Base URL (Critical for media) ----
# Point to Nginx protected URL (e.g. https://api.your-domain.com/uploads)
UPLOADS_BASE_URL=https://api.your-domain.com/uploads

# ---- Encryption (Optional) ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
